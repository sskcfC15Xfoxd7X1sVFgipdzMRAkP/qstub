{
  "name": "qstub",
  "version": "0.1.0",
  "description": "A local development server that mocks the QStash API for fast, offline testing.",
  "type": "module",
  "bin": {
    "qstub": "./src/cli.ts"
  },
  "scripts": {
    "start": "bun src/cli.ts",
    "build": "bun build src/cli.ts --target=bun --outdir=dist",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check ."
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "files": ["src", "README.md", "LICENSE"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/doomspork/qstub.git"
  },
  "keywords": ["qstash", "upstash", "mock", "local-development", "bun", "hono"],
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.1.14",
    "@upstash/qstash": "^2.7.20",
    "typescript": "^5.7.2"
  }
}
